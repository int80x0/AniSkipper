{
  "manifest_version": 2,
  "name": "AniSkipper",
  "version": "1.1.7",
  "description": "Erkennt HTML5-Player und skippt Anime-Openings mit einem Klick (+1:30).",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "webNavigation",
    "<all_urls>"
  ],
  "browser_action": {
    "default_title": "AniSkipper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "aniskipper@sunhaven.int80x0.xyz",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": [
      "background/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content-script.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
